# Request a free key at https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Optional PEM certificate for networks or antivirus software that inspect HTTPS.
# Keep machine-specific certificates in .local-certs/, which is git-ignored.
FIRMS_CA_CERT=

# MTG-FCI compatibility feed from the public Tabula Caloris live index.
# This is the fast free geostationary source for 10-minute observations.
CALORIS_MTG_BRIDGE=true
CALORIS_BASE_URL=https://forefire.univ-corse.fr/calormap/
CALORIS_TIMEOUT_MS=90000
CALORIS_INDEX_TIMEOUT_MS=60000
CALORIS_REQUEST_TIMEOUT_MS=15000
CALORIS_STALE_MS=600000

# Independent anonymous freshness check against the official LSA SAF WMS.
# Detection points still come from the compatibility bridge above.
LSASAF_STATUS_CHECK=true
LSASAF_WMS_URL=https://adaguc.lsasvcs.ipma.pt/adaguc-server?DATASET=MTG-FRP&SERVICE=WMS&REQUEST=GetCapabilities&VERSION=1.3.0
LSASAF_STATUS_TIMEOUT_MS=15000
LSASAF_MAX_LAG_MS=3600000
PROVIDER_STATUS_STALE_MS=900000

# Required application login. Keep real credentials only in .env.
APP_LOGIN_USER=
APP_LOGIN_PASSWORD=
APP_SESSION_HOURS=12
# Trust client IPs from X-Forwarded-For only behind a proxy that overwrites that header.
APP_TRUST_FORWARDED_FOR=false

# west,south,east,north. The default includes Lebanon, Rif Dimashq, Homs, and northern Israel.
FIRE_BBOX=34.75,32.75,36.75,34.75

# Optional server settings.
PORT=4173
FIRMS_CACHE_MS=240000
FIRMS_TIMEOUT_MS=45000
